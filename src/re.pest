WHITESPACE = _{ " " | "\t" }

// Base identifier: starts with letter or underscore, followed by alphanumeric or underscore
identifier = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }

// Literal types
integer = @{ "-"? ~ ASCII_DIGIT+ }
float = @{ "-"? ~ ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+ ~ (("e" | "E") ~ ("-" | "+")? ~ ASCII_DIGIT+)? }
string = @{ "\"" ~ (("\\" ~ ANY) | (!"\"" ~ ANY))* ~ "\"" }

// Index values for bracket accessors: only integers or strings (no identifiers or floats)
index_value = { integer | string }

// Accessor suffix: either dot access (. identifier) or bracket access ([ index_value ])
accessor_suffix = { ("." ~ identifier) | ("[" ~ index_value ~ "]") }

// Accessor chain: identifier followed by zero or more accessor suffixes
accessor_chain = { identifier ~ accessor_suffix* }

// Function arguments: only literals (no identifiers, accessors, or nested calls)
arg = { float | integer | string }

// Direct function call: identifier(arg, arg, ...)
function_call = { identifier ~ "(" ~ (arg ~ ("," ~ arg)*)? ~ ")" }

// Method call: accessor_chain:identifier(arg, arg, ...)
method_call = { accessor_chain ~ ":" ~ identifier ~ "(" ~ (arg ~ ("," ~ arg)*)? ~ ")" }

// Value: can be a method call, function call, accessor chain, or literal
// Order matters: try more specific patterns first
value = { method_call | function_call | accessor_chain | float | integer | string }

// Program: a single value (no assignments)
program = { SOI ~ value ~ EOI }